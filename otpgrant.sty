%% otpgrant.sty -- shared preamble for FY2026 OTP (84.116T) application documents
%% Implements ED discretionary grant formatting standards (2025 Common Instructions):
%%   * 8.5" x 11" letter paper, 1" margins on all sides
%%   * 12pt Times (or Times-like) font
%%   * page numbers
%%   * double spacing for the project narrative (toggle per document)
%% Compile with pdflatex to produce a flattened, non-fillable PDF as ED recommends.
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{otpgrant}[2026/06/12 OTP grant formatting]

\RequirePackage[letterpaper,margin=1in]{geometry}
\RequirePackage{microtype}
% Times text + math. Prefer newtx (modern); fall back to mathptmx on minimal installs.
\RequirePackage{stix2}

\RequirePackage[scale=.85]{FiraMono}

\usepackage[backend=biber, style=numeric]{biblatex}
\addbibresource{references.bib}

\RequirePackage{setspace}      % \doublespacing / \singlespacing per document
\RequirePackage[hidelinks]{hyperref} % internal links, no colored boxes in print

\RequirePackage{standalone}     % for documents that can be compiled on their own (abstract, budget narrative)
\RequirePackage{tikz}           % for drawing diagrams; load before titlesec to avoid conflicts
\usetikzlibrary{backgrounds,fit,matrix}
\usetikzlibrary{shapes, arrows}
\tikzstyle{terminator} = [outer sep=2pt,thick,rectangle, draw, text centered, rounded corners, minimum height=2em]


\tikzstyle{objective} = [outer sep=2pt,thick,rectangle, draw, text centered, minimum height=2em]

\tikzstyle{output}=[outer sep=2pt,thick,trapezium, draw, text centered, trapezium left angle=60, trapezium right angle=120, minimum height=2em]
\tikzstyle{connector} = [draw, black!50!white,ultra thick, -stealth]
\RequirePackage{booktabs}
\RequirePackage{array}
\RequirePackage{longtable}       % for better tables; load after geometry to avoid conflicts

% Page numbers, bottom center (LaTeX "plain" default) -- nothing else needed.
\pagestyle{plain}

% Keep the TOC to depth 1 so it fits the one-double-spaced-page limit.
\setcounter{tocdepth}{3}

% Headers stay readable and modest; no color, no decoration.
\RequirePackage{titlesec}
\titleformat{\section}{\normalfont\bfseries}{\thesection.}{0.5em}{}
\titleformat{\subsection}{\normalfont\bfseries}{\thesubsection}{0.5em}{}
\titleformat{\paragraph}[runin]{\normalfont\normalsize\bfseries}{}{}{}
\titlespacing*{\paragraph}{0pt}{*4}{1em}



\titleformat{\subsubsection}[runin]{\normalfont\normalsize\bfseries}{\thesubsubsection.}{0.5em}{}
\titlespacing*{\subsubsection}{0pt}{*4}{1em}
% Convenience: a labeled criterion header showing reviewer point values,
% e.g. \criterion{Need for the Project}{12}
\newcommand{\criterion}[2]{\section{#1 (up to #2 points)}}

\endinput
